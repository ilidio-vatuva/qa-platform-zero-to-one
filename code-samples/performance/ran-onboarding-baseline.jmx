<?xml version="1.0" encoding="UTF-8"?>
<!--
  RAN onboarding baseline — illustrative JMeter scenario.

  Purpose
  -------
  Establish a *baseline* for network-element onboarding throughput and
  latency under a realistic-but-modest load. Used as a release-candidate
  gate against staging (see /architecture/test-execution-flow.md §5).

  Why JMeter, kept structurally separate
  --------------------------------------
  Performance lives outside the per-commit pipeline by design — different
  cadence (nightly / weekly), different gates (latency percentiles, not
  pass/fail), different audience (SRE + product).
  See /architecture/system-architecture.md#performance-jmeter.

  Shape of this plan
  ------------------
  * Thread group: 20 virtual users, 60-second ramp-up, 5-minute steady run.
  * Each user repeatedly POSTs to /network-elements and polls /status.
  * Two response assertions: HTTP 202 on submit, HTTP 200 on poll.
  * One duration assertion: p95 submit latency under 800 ms.

  How to run
  ----------
    jmeter -n -t performance/ran-onboarding-baseline.jmx \
           -Jhost=api.staging.example.internal -Jport=443 -Jscheme=https \
           -l performance/results/baseline.jtl

  This file is deliberately minimal: a single thread group, a single flow,
  a single SLA assertion. Larger plans (soak, spike, vendor mix) belong in
  sibling .jmx files so each test has one job.
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="RAN Onboarding Baseline" enabled="true">
      <stringProp name="TestPlan.comments">Baseline latency + throughput for network-element onboarding.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="host" elementType="Argument">
            <stringProp name="Argument.name">host</stringProp>
            <stringProp name="Argument.value">${__P(host,localhost)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="port" elementType="Argument">
            <stringProp name="Argument.name">port</stringProp>
            <stringProp name="Argument.value">${__P(port,8080)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="scheme" elementType="Argument">
            <stringProp name="Argument.name">scheme</stringProp>
            <stringProp name="Argument.value">${__P(scheme,http)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ============== Defaults shared by every sampler ============== -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults" enabled="true">
        <stringProp name="HTTPSampler.domain">${host}</stringProp>
        <stringProp name="HTTPSampler.port">${port}</stringProp>
        <stringProp name="HTTPSampler.protocol">${scheme}</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">5000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">10000</stringProp>
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments"/>
      </ConfigTestElement>
      <hashTree/>

      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Content-Type</stringProp>
            <stringProp name="Header.value">application/json</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <!-- ============== Thread group: 20 VUs, 60s ramp, 5min run ============== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Onboarding VUs" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">60</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">300</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>

        <!-- One unique element per iteration: __UUID keeps the namespace clean. -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /network-elements" enabled="true">
          <stringProp name="HTTPSampler.path">/network-elements</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{
  "elementId": "el-${__UUID}",
  "vendor": "vendor-a",
  "region": "eu-west",
  "tags": { "env": "perf" }
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- SLA gate: every submit must return 202. -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Status 202" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49587">202</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- p95 latency budget for the submit endpoint. -->
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Submit under 800 ms" enabled="true">
            <stringProp name="DurationAssertion.duration">800</stringProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>

        <!-- Think time between submit and poll: 200ms +/- jitter. -->
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think time" enabled="true">
          <stringProp name="ConstantTimer.delay">200</stringProp>
          <stringProp name="RandomTimer.range">100</stringProp>
        </UniformRandomTimer>
        <hashTree/>

      </hashTree>

      <!-- ============== Result collectors (kept light for CI) ============== -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report" enabled="true">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <stringProp name="filename">results/baseline.jtl</stringProp>
      </ResultCollector>
      <hashTree/>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
